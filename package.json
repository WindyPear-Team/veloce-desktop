{
  "name": "veloce-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "install:mirror": "node scripts/install-with-mirror.mjs",
    "install:electron": "node scripts/install-electron-with-mirror.mjs",
    "build:web": "npm --prefix ../web run build:desktop",
    "build:electron": "tsc -p tsconfig.json",
    "build": "npm run build:web && npm run build:electron",
    "start": "npm run build && electron ."
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "electron": "^38.0.0",
    "typescript": "~6.0.2"
  },
  "allowScripts": {}
}
